# ─── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL — obtener en https://neon.tech o https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/express_service?sslmode=require"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"

# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Credenciales de la cuenta PLATAFORMA (marketplace owner)
MP_ACCESS_TOKEN="APP_USR-xxxxx"
MP_PUBLIC_KEY="APP_USR-xxxxx"
MP_CLIENT_ID="xxxxx"
MP_CLIENT_SECRET="xxxxx"
# ID del Marketplace en MP (obtenido al homologar)
MP_MARKETPLACE_ID="xxxxx"
# URL de notificaciones (debe ser pública, no localhost)
MP_NOTIFICATION_URL="https://tu-dominio.vercel.app/api/webhooks/mercadopago"
# Secret para validar firma del webhook
MP_WEBHOOK_SECRET="xxxxx"

# ─── WhatsApp Cloud API (Meta) ────────────────────────────────────────────────
# Obtener en https://developers.facebook.com → Tu App → WhatsApp → Configuración
WA_PHONE_NUMBER_ID="xxxxx"
WA_API_TOKEN="EAAxxxxx"

# ─── Resend (Email transaccional) ────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Precios ─────────────────────────────────────────────────────────────────
# Precio de mano de obra por minuto en ARS (ajustar según el mercado)
LABOR_RATE_PER_MINUTE=400

# ─── Cron Jobs (Vercel) ───────────────────────────────────────────────────────
# Vercel inyecta este secret automáticamente; también se puede definir acá
CRON_SECRET="un-secret-aleatorio-largo"

# ─── Alertas internas ────────────────────────────────────────────────────────
# Webhook interno para alertas al backoffice (ej: Slack, Discord, n8n)
ADMIN_ALERT_WEBHOOK_URL="https://hooks.slack.com/services/xxxxx"
